*.log
logs/

# ── Test / coverage artefacts ─────────────────────────────────────────────────
# JaCoCo generates these under target/ which is already ignored,
# but be explicit to avoid accidental commits if target is removed from .gitignore.
jacoco.exec
jacoco-it.exec
